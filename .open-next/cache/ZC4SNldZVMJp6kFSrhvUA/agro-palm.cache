lm%2Fimage3.jpeg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fagro-palm%2Fimage3.jpeg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fagro-palm%2Fimage3.jpeg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fagro-palm%2Fimage3.jpeg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fagro-palm%2Fimage3.jpeg&amp;w=3840&amp;q=75\"/></div></div><div class=\"relative w-full lg:w-1/2 h-[60vh] lg:h-full flex flex-col justify-between p-8 sm:p-12 lg:p-20 xl:p-24\"><div class=\"flex items-center gap-2 lg:gap-3\"><div class=\"flex items-center justify-center w-8 h-8 lg:w-10 lg:h-10 rounded-full font-unbounded text-[10px] lg:text-xs font-bold shadow-sm\">0<!-- -->1</div><div class=\"flex items-center justify-center w-8 h-8 lg:w-10 lg:h-10 rounded-full font-unbounded text-[10px] lg:text-xs font-bold shadow-sm\">0<!-- -->2</div><div class=\"flex items-center justify-center w-8 h-8 lg:w-10 lg:h-10 rounded-full font-unbounded text-[10px] lg:text-xs font-bold shadow-sm\">0<!-- -->3</div></div><div class=\"w-full mt-auto mb-8 lg:my-auto\"><div class=\"relative w-full min-h-[5.5rem] sm:min-h-[6.5rem] md:min-h-[8rem] lg:min-h-[10rem]\"><div class=\"absolute inset-0 flex flex-col justify-center\" style=\"opacity:0;filter:blur(8px);transform:translateY(30px) scale(0.98)\"><h2 class=\"font-unbounded text-xl font-bold uppercase leading-[1.15] tracking-tight text-balance sm:text-2xl md:text-3xl lg:text-4xl xl:text-[2.75rem]\" aria-label=\"De la palmeraie à l’huile certifiée marchés\"><span>De la </span><span style=\"color:#f7d616\" class=\"font-black\">palmeraie</span><span> à l’huile certifiée </span><span style=\"color:#f7d616\" class=\"font-black\">marchés</span></h2></div><div class=\"absolute inset-0 flex flex-col justify-center\" style=\"opacity:0;filter:blur(8px);transform:translateY(30px) scale(0.98)\"><h2 class=\"font-unbounded text-xl font-bold uppercase leading-[1.15] tracking-tight text-balance sm:text-2xl md:text-3xl lg:text-4xl xl:text-[2.75rem]\" aria-label=\"Ressources nationales, emplois et communautés\"><span style=\"color:#3d632f\" class=\"font-black\">Ressources</span><span> nationales, </span><span style=\"color:#3d632f\" class=\"font-black\">emplois</span><span> et communautés</span></h2></div><div class=\"absolute inset-0 flex flex-col justify-center\" style=\"opacity:0;filter:blur(8px);transform:translateY(30px) scale(0.98)\"><h2 class=\"font-unbounded text-xl font-bold uppercase leading-[1.15] tracking-tight text-balance sm:text-2xl md:text-3xl lg:text-4xl xl:text-[2.75rem]\" aria-label=\"Méthodes responsables et conformité industrielle\"><span>Méthodes </span><span style=\"color:#f7d616\" class=\"font-black\">responsables</span><span> et conformité </span><span style=\"color:#f7d616\" class=\"font-black\">industrielle</span></h2></div></div></div><div class=\"w-full max-w-xl relative flex flex-col justify-end min-h-[160px] lg:min-h-[180px]\"><div class=\"relative w-full h-24 lg:h-28\"><div class=\"absolute inset-0\" style=\"opacity:0;filter:blur(4px);transform:translateY(20px)\"><p class=\"font-sora text-sm md:text-base lg:text-lg leading-relaxed opacity-90 text-pretty font-medium\">Maîtrisant l’ensemble de la chaîne de valeur, de la culture des palmeraies à la transformation des fruits, nous assurons la production d’une huile de palme répondant rigoureusement aux exigences des marchés locaux et internationaux.</p></div><div class=\"absolute inset-0\" style=\"opacity:0;filter:blur(4px);transform:translateY(20px)\"><p class=\"font-sora text-sm md:text-base lg:text-lg leading-relaxed opacity-90 text-pretty font-medium\">Notre mission consiste à valoriser les ressources naturelles nationales tout en favorisant la création d’emplois locaux et le développement économique des communautés environnantes.</p></div><div class=\"absolute inset-0\" style=\"opacity:0;filter:blur(4px);transform:translateY(20px)\"><p class=\"font-sora text-sm md:text-base lg:text-lg leading-relaxed opacity-90 text-pretty font-medium\">Par le recours à des méthodes de production optimisées et responsables, nous nous engageons à fournir des produits fiables, compétitifs et strictement conformes aux besoins des industries alimentaires et non alimentaires.</p></div></div><div class=\"mt-6 w-fit rounded-full shadow-lg\"></div></div></div></div></div></main><section class=\"bg-background pt-24 font-sans md:pt-32\"><div class=\"mx-auto w-[min(100%,80rem)] px-6\"><div class=\"relative z-10 -mb-20 md:-mb-24\"><div class=\"group relative h-[min(22rem,70vw)] overflow-hidden rounded-2xl shadow-[0_24px_60px_-12px_rgba(29,29,27,0.25)] md:h-96\"><img alt=\"Champs — CAP Congo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover opacity-90 transition-transform duration-700 group-hover:scale-[1.03]\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 1280px) 100vw, 80rem\" srcSet=\"/_next/image?url=%2Fimages%2Fmais.webp&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fmais.webp&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fmais.webp&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fmais.webp&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fmais.webp&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fmais.webp&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fmais.webp&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fmais.webp&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fmais.webp&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-r from-cap-forest/85 via-cap-dark-green/70 to-transparent\"></div><div class=\"absolute inset-0 flex flex-col justify-center p-8 md:p-16 lg:p-24\"><h2 class=\"mb-6 max-w-2xl font-unbounded text-3xl font-bold leading-tight tracking-tight text-background md:text-5xl lg:text-6xl\">Produire local, nourrir durablement.</h2></div></div></div></div><div class=\"w-full px-6\"><div class=\"rounded-t-3xl bg-cap-ink pb